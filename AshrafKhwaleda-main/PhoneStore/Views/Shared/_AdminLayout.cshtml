@{
    // لا نحتاج المفتاح السري هنا بعد الآن
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة التحكم</title>
    <meta name="theme-color" content="#513061">
    <link href="~/css/bootstrap.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/all.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/admin.css" rel="stylesheet" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">
</head>
<body>
    <div id="wrapper" class="toggled-on-desktop">
        <div class="sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>
        <!-- القائمة الجانبية -->
        <div id="sidebar-wrapper">
            <div class="sidebar-heading">
                <a asp-controller="Admin" asp-action="Index">لوحة التحكم</a>
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action"
                   asp-route-controller="Admin" asp-action="Index">
                    <i class="fas fa-tachometer-alt fa-fw me-2"></i> لوحة التحكم
                </a>
                <a asp-controller="AdminOrders" asp-action="Index" class="list-group-item list-group-item-action"
                   asp-route-controller="AdminOrders">
                    <i class="fas fa-receipt fa-fw me-2"></i> إدارة الطلبات
                </a>
                <a asp-controller="AdminProducts" asp-action="Index" class="list-group-item list-group-item-action"
                   asp-route-controller="AdminProducts">
                    <i class="fas fa-mobile-alt fa-fw me-2"></i> إدارة المنتجات
                </a>
                <!-- رابط الأقسام الجديد -->
                <a asp-controller="AdminCategories" asp-action="Index" class="list-group-item list-group-item-action"
                   asp-route-controller="AdminCategories">
                    <i class="fas fa-tags fa-fw me-2"></i> إدارة الأقسام
                </a>
                <a asp-controller="AdminCompanies" asp-action="Index" class="list-group-item list-group-item-action"
                   asp-route-controller="AdminCompanies">
                    <i class="fas fa-building fa-fw me-2"></i> إدارة الشركات
                </a>
                <a asp-controller="AdminLocations" asp-action="Index" class="list-group-item list-group-item-action"
                   asp-route-controller="AdminLocations">
                    <i class="fas fa-map-marked-alt fa-fw me-2"></i> مناطق التوصيل
                </a>
                <!-- الرابط الجديد -->
                <a asp-controller="AdminAnnouncements" asp-action="Index" class="list-group-item list-group-item-action"
                   asp-route-controller="AdminAnnouncements">
                    <i class="fas fa-bullhorn fa-fw me-2"></i> شريط الإعلانات
                </a>
                <a asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="fas fa-store fa-fw me-2"></i> العودة للمتجر
                </a>
            </div>
        </div>

        <!-- محتوى الصفحة -->
        <div id="page-content-wrapper">
            <nav class="admin-topbar">
                <button class="btn btn-primary" id="menu-toggle" aria-label="فتح القائمة الجانبية">
                    <i class="fas fa-bars"></i>
                </button>
                <h5 class="admin-topbar__title">@ViewData["Title"]</h5>

                <form asp-controller="Account" asp-action="Logout" method="post" class="admin-topbar__logout">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="fas fa-sign-out-alt me-1 me-md-2"></i>
                        <span class="d-none d-md-inline">تسجيل الخروج</span>
                    </button>
                </form>
            </nav>

            <div class="admin-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var wrapper = document.getElementById("wrapper");
            var toggle = document.getElementById("menu-toggle");
            var backdrop = document.getElementById("sidebarBackdrop");

            function close() { wrapper.classList.remove("toggled"); }
            function open() { wrapper.classList.add("toggled"); }

            toggle.addEventListener("click", function (e) {
                e.preventDefault();
                wrapper.classList.toggle("toggled");
            });
            backdrop.addEventListener("click", close);

            // إغلاق السايدبار تلقائياً عند الضغط على رابط (موبايل فقط)
            document.querySelectorAll("#sidebar-wrapper .list-group-item-action").forEach(function (link) {
                link.addEventListener("click", function () {
                    if (window.innerWidth < 992) close();
                });
            });

            // إغلاق بزر Escape
            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape") close();
            });

            // تفعيل الرابط النشط
            var currentController = "@ViewContext.RouteData.Values["controller"]?.ToString()";
            var currentAction = "@ViewContext.RouteData.Values["action"]?.ToString()";
            document.querySelectorAll("#sidebar-wrapper .list-group-item-action").forEach(function (link) {
                var linkController = link.getAttribute("asp-route-controller");
                var linkAction = link.getAttribute("asp-route-action") || "Index";
                if (linkController === currentController && (linkAction === currentAction || (currentController === "Admin" && linkAction === "Index"))) {
                    link.classList.add("active");
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>