@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using PhoneStore.Extensions
@using System.Text.Json

<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - متجر أشرف الخوالدة</title>

    @{
        var pageDescription = (ViewData["Description"] as string)
            ?? "متجر أشرف الخوالدة لقطع غيار الموبايلات الأصلية وأحدث ماركات الهواتف الذكية بأفضل الأسعار في الأردن.";
        var pageKeywords = (ViewData["Keywords"] as string)
            ?? "موبايلات, قطع غيار موبايلات, هواتف ذكية, ايفون, سامسونج, شاومي, الأردن, اشرف الخوالدة";
        var pageOgImage = (ViewData["OgImage"] as string) ?? "/images/header.jpg";
        var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}{Context.Request.QueryString}";
    }

    <meta name="description" content="@pageDescription">
    <meta name="keywords" content="@pageKeywords">
    <meta name="author" content="أشرف الخوالدة">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="@canonicalUrl">

    <meta property="og:type" content="website">
    <meta property="og:title" content="@ViewData["Title"] - متجر أشرف الخوالدة">
    <meta property="og:description" content="@pageDescription">
    <meta property="og:image" content="@pageOgImage">
    <meta property="og:url" content="@canonicalUrl">
    <meta property="og:locale" content="ar_AR">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@ViewData["Title"] - متجر أشرف الخوالدة">
    <meta name="twitter:description" content="@pageDescription">
    <meta name="twitter:image" content="@pageOgImage">

    <meta name="theme-color" content="#513061">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/all.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/bootstrap.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">

    <script>
        // الوضع الافتراضي: فاتح. الداكن يفعّل فقط عند اختيار المستخدم له صراحة.
        (function () {
            try {
                if (localStorage.getItem('theme') === 'dark') {
                    document.documentElement.classList.add('dark');
                }
            } catch (e) { }
        })();
    </script>
    <style>
        #toast-container {
            position: fixed;
            top: 80px;
            left: 20px;
            z-index: 9999;
        }

        .icon-wrapper .btn {
            position: relative;
        }

        .badge-count {
            position: absolute;
            top: -8px;
            right: -8px;
            background-color: #dc3545;
            color: #fff;
            border-radius: 50%;
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
            font-weight: bold;
            line-height: 1;
            border: 2px solid #fff;
        }

        /* ستايل الفوتر */
        .footer-professional {
            background-color: #212529;
            color: #adb5bd;
            padding-top: 4rem;
            font-size: 0.9rem;
        }

            .footer-professional h5 {
                color: #fff;
                font-weight: 700;
                margin-bottom: 1.5rem;
                position: relative;
                padding-bottom: 10px;
            }

                .footer-professional h5::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    right: 0;
                    width: 50px;
                    height: 2px;
                    background-color: #513061;
                }

            .footer-professional a {
                color: #adb5bd;
                text-decoration: none;
                transition: all 0.3s;
                display: block;
                margin-bottom: 0.5rem;
            }

                .footer-professional a:hover {
                    color: #fff;
                    transform: translateX(-5px);
                }

        .social-links a {
            display: inline-block;
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.1);
            line-height: 40px;
            text-align: center;
            border-radius: 50%;
            margin-left: 10px;
            color: #fff;
        }

            .social-links a:hover {
                background: #513061;
                transform: translateY(-3px);
            }

        .footer-bottom {
            background-color: #1a1e21;
            padding: 1.5rem 0;
            margin-top: 3rem;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <!-- استدعاء شريط الإعلانات -->
    @await Component.InvokeAsync("Announcement")

    @Html.AntiForgeryToken()

    <header id="header" class="header sticky-top bg-white shadow-sm">
        <nav class="navbar navbar-expand-lg px-3">
            <div class="container-fluid container-lg align-items-center p-2">
                <a class="navbar-brand m-0" asp-controller="Home" asp-action="Index">
                    <span class="brand-text-accent">اشرف الخوالدة</span>
                </a>

                <!-- مربع البحث الذي طلبته (تمت إضافته هنا) -->
                <form class="d-flex flex-grow-1 mx-2 mx-md-4" asp-controller="Store" asp-action="Index" method="get" style="max-width: 450px;">
                    <div class="input-group input-group-sm">
                        <input type="search" name="searchString" class="form-control shadow-none border-secondary-subtle" style="border-radius:0px 5px 5px 0" placeholder="ابحث عن منتج...">
                        <button class="btn text-white px-2 px-md-3" style="background-color: #513061;border-radius:5px 0 0 5px " type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>

                <button class="navbar-toggler border-0 px-1 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <i class="fa-solid fa-bars fs-4"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto d-flex gap-3 gap-lg-2 mt-3 mt-lg-0 py-3">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="home">الرئيسية</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="mobileCompany">شركة الموبايلات</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="Index">المتجر</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="whyUs">لماذا نحن</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="contact">اتصل بنا</a></li>
                    </ul>
                    <div class="px-lg-4">
                        <div class="icon-wrapper d-flex gap-4 py-3 py-lg-0 justify-content-center justify-content-lg-start">
                            @{
                                var cart = HttpContextAccessor.HttpContext.Session.GetObject<List<PhoneStore.Models.CartItem>>("_Cart") ?? new List<PhoneStore.Models.CartItem>();
                                var cartCount = cart.Sum(c => c.Quantity);

                                var wishlistCookie = HttpContextAccessor.HttpContext.Request.Cookies["PhoneStore_Wishlist"];
                                var wishlistCount = 0;
                                if (!string.IsNullOrEmpty(wishlistCookie))
                                {
                                    try { wishlistCount = (JsonSerializer.Deserialize<List<int>>(wishlistCookie) ?? new List<int>()).Count; } catch { }
                                }
                            }

                            <div>
                                <a asp-controller="Cart" asp-action="Wishlist" class="btn btn-danger btn-lg" id="wishlist-link"
                                   aria-label="قائمة المفضلة (@wishlistCount عنصر)">
                                    <i class="fa-regular fa-heart fa-lg" title="Wishlist" aria-hidden="true"></i>
                                    <span class="badge-count @(wishlistCount > 0 ? "" : "d-none")">@wishlistCount</span>
                                </a>
                            </div>
                            <div>
                                <a asp-controller="Cart" asp-action="Index" class="btn btn-danger btn-lg position-relative" id="cart-link"
                                   aria-label="سلة التسوق (@cartCount عنصر)">
                                    <i class="fa-solid fa-cart-shopping fa-lg" title="Cart" aria-hidden="true"></i>
                                    <span class="badge-count @(cartCount > 0 ? "" : "d-none")">@cartCount</span>
                                </a>
                            </div>
                            <div>
                                <a asp-controller="Order" asp-action="Index" class="btn btn-danger btn-lg" aria-label="طلباتي">
                                    <i class="fa-solid fa-receipt" aria-hidden="true"></i>
                                </a>
                            </div>
                            <div class="d-flex align-items-center">
                                <button type="button" class="theme-switch" id="themeSwitch" role="switch" aria-checked="false" aria-label="تبديل الوضع الداكن" title="تبديل الوضع الداكن">
                                    <span class="theme-switch__track">
                                        <i class="fa-solid fa-sun theme-switch__icon theme-switch__icon--sun" aria-hidden="true"></i>
                                        <i class="fa-solid fa-moon theme-switch__icon theme-switch__icon--moon" aria-hidden="true"></i>
                                        <span class="theme-switch__thumb">
                                            <i class="fa-solid fa-moon" aria-hidden="true"></i>
                                        </span>
                                    </span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" style="min-height: 60vh;">
        @RenderBody()
    </main>

    <div aria-live="polite" aria-atomic="true" class="position-relative">
        <div id="toast-container"></div>
    </div>

    <!-- أيقونة الواتساب العائمة -->
    <a href="https://wa.me/962792747477" class="whatsapp-float" target="_blank" title="تواصل معنا عبر واتساب">
        <i class="fab fa-whatsapp"></i>
    </a>

    <style>
        .whatsapp-float {
            position: fixed;
            width: 60px;
            height: 60px;
            bottom: 30px;
            right: 30px;
            background-color: #25d366;
            color: #FFF;
            border-radius: 50px;
            text-align: center;
            font-size: 35px;
            box-shadow: 0px 4px 10px rgba(0,0,0,0.3);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.3s ease;
        }

            .whatsapp-float:hover {
                background-color: #20b858;
                color: white;
                transform: scale(1.1);
            }
        /* إخفاء الأيقونة عند الطباعة */
        @@media print {
            .whatsapp-float

        {
            display: none !important;
        }

        }
    </style>

    <!-- الفوتر الاحترافي الجديد -->
    <footer class="footer-professional">
        <div class="container">
            <div class="row gy-4">
                <!-- العمود الأول: اللوجو ونبذة -->
                <div class="col-lg-4 col-md-6">
                    <div class="mb-4">
                        <!-- مكان اللوجو -->
                        <h5 class="text-white ">أشرف الخوالدة</h5>
                    </div>
                    <p class="mb-4">
                        وجهتك الأولى لقطع غيار الموبايلات الأصلية. نضمن لك الجودة، السرعة في التوصيل، وأفضل الأسعار في السوق.
                    </p>
                    <div class="social-links">
                        <a href="https://facebook.com" target="_blank"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://instagram.com" target="_blank"><i class="fab fa-instagram"></i></a>
                        <a href="https://wa.me/962792747477" target="_blank"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>

                <!-- العمود الثاني: روابط سريعة -->
                <div class="col-lg-2 col-md-6">
                    <h5>روابط سريعة</h5>
                    <a asp-controller="Home" asp-action="Index">الرئيسية</a>
                    <a asp-controller="Store" asp-action="Index">المتجر</a>
                    <a asp-controller="Cart" asp-action="Index">سلة التسوق</a>
                    <a asp-controller="Order" asp-action="Index">طلباتي</a>
                </div>

                <!-- العمود الثالث: معلومات -->
                <div class="col-lg-2 col-md-6">
                    <h5>معلومات</h5>
                    <a asp-controller="Home" asp-action="Index" asp-fragment="about">من نحن</a>
                    <a asp-controller="Home" asp-action="Index" asp-fragment="contact">اتصل بنا</a>
                    <a href="#">سياسة الخصوصية</a>
                    <a href="#">شروط الاستخدام</a>
                </div>

                <!-- العمود الرابع: تواصل معنا -->
                <div class="col-lg-4 col-md-6">
                    <h5>تواصل معنا</h5>
                    <p><i class="fas fa-map-marker-alt me-2 text-white"></i> الأردن، عمان، شارع الجاردنز</p>
                    <p><i class="fas fa-phone me-2 text-white"></i> <a href="tel:0792747477" class="d-inline text-white-50" dir="ltr">+962 79 274 7477</a></p>
                    <p><i class="fas fa-envelope me-2 text-white"></i> info@ashrafstore.com</p>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="container text-center">
                <p class="mb-0">&copy; @DateTime.Now.Year جميع الحقوق محفوظة | <strong>أشرف الخوالدة</strong></p>
            </div>
        </div>
    </footer>

    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>

    <script src="~/js/main.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        // Theme switch (الوضع الافتراضي فاتح)
        (function () {
        var btn = document.getElementById('themeSwitch');
        if (!btn) return;
        var thumbIcon = btn.querySelector('.theme-switch__thumb i');
        function syncState() {
            var dark = document.documentElement.classList.contains('dark');
            btn.setAttribute('aria-checked', dark ? 'true' : 'false');
            btn.setAttribute('title', dark ? 'تفعيل الوضع الفاتح' : 'تفعيل الوضع الداكن');
            if (thumbIcon) {
                thumbIcon.className = dark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
            }
        }
        syncState();
        btn.addEventListener('click', function () {
            var dark = document.documentElement.classList.toggle('dark');
            try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) { }
            syncState();
        });
    })();

        // Mark images as loaded to disable skeleton background
        document.addEventListener('load', function (e) {
            var t = e.target;
            if (t && t.tagName === 'IMG' && t.getAttribute('loading') === 'lazy') {
                t.dataset.loaded = '1';
            }
        }, true);

        // Map known brand names to existing logo files in /images/
        var BRAND_LOGOS = {
            'apple': '/images/apple.png',
            'iphone': '/images/iphone.png',
            'samsung': '/images/samsung.png',
            'xiaomi': '/images/Xiaomi-Logo.png',
            'redmi': '/images/Xiaomi-Logo.png',
            'poco': '/images/POCO-logo.svg.png',
            'infinex': '/images/infinix-logo-hd.webp',
            'infinix': '/images/infinix-logo-hd.webp',
            'tecno': '/images/tecno-mobile-logo-icon.webp',
            'honor': '/images/Honor.svg',
            'lenovo': '/images/lenovo.png',
            'one plus': '/images/OnePlus-Logo.png',
            'oneplus': '/images/OnePlus-Logo.png',
            'google pixel': '/images/pixel.webp',
            'pixel': '/images/pixel.webp',
            'tcl': '/images/tcl.webp',
            'huawei': '/images/huawei.png',
            'motorola': '/images/motorola-logo-png-transparent.png',
            'allcall': '/images/all-call.png',
            'all call': '/images/all-call.png',
            'alcatel': '/images/alcatel.png',
            'alcate': '/images/alcatel.png',
            'zte': '/images/ZTE.png',
            'itel': '/images/Itel-mobile-logo-vector.svg.png',
            'nokia': '/images/nokia.png',
            'hisense': '/images/Hisense.png',
            'heinses': '/images/Hisense.png',
            'black shark': '/images/Black-Shark.jpg',
            'blackshark': '/images/Black-Shark.jpg',
            'black view': '/images/Black-Shark.jpg',
            'blackview': '/images/Black-Shark.jpg',
            'oppo': '/images/Oppo-Logo.svg',
            'vivo': '/images/Vivo-Logo.png',
            'sony': '/images/sony.png',
            'kgtel': '/images/kgtel.webp',
            'kxd': '/images/kxd.avif'
        };

        function pickBrandLogo(alt) {
            if (!alt) return null;
            var key = alt.toLowerCase().trim();
            if (BRAND_LOGOS[key]) return BRAND_LOGOS[key];
            for (var k in BRAND_LOGOS) {
                if (key.indexOf(k) !== -1 || k.indexOf(key) !== -1) return BRAND_LOGOS[k];
            }
            return null;
        }

        document.addEventListener('error', function (e) {
            var t = e.target;
            if (t && t.tagName === 'IMG' && !t.dataset.fallbackApplied) {
                t.dataset.fallbackApplied = '1';
                var logo = pickBrandLogo(t.alt);
                if (logo) {
                    t.src = logo;
                } else {
                    var label = (t.alt || 'No Image').replace(/[^\w\s؀-ۿ-]/g, '').trim() || 'No Image';
                    t.src = 'https://placehold.co/400x400/EEE/513061?text=' + encodeURIComponent(label);
                }
            }
        }, true);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>